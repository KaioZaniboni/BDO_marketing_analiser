# ==========================================
# BDO Market Analyzer — Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env.local e preencha os valores

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bdo_market?schema=public"

# Redis (Upstash ou local)
REDIS_URL="redis://localhost:6379"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-secret-seguro-aqui-com-openssl-rand-base64-32"

# Cron externo (Vercel/HTTP scheduler)
CRON_SECRET="gere-um-token-longo-e-aleatorio"

# BDO Market API (opcional - usado como fallback)
BDO_MARKET_SA_URL="https://market.sa.playblackdesert.com"

# Arsha.io (API wrapper pública)
ARSHA_API_URL="https://api.arsha.io"
ARSHA_REGION="sa"

# Auto-sync interno para ambientes locais/self-hosted.
# Em Vercel, o projeto usa Cron externo e isso fica desligado por padrão.
MARKET_AUTO_SYNC_ENABLED="true"
MARKET_SNAPSHOT_MAX_AGE_MS="900000"
MARKET_SNAPSHOT_CHECK_INTERVAL_MS="60000"
MARKET_HISTORY_CHECK_INTERVAL_MS="1800000"
MARKET_AUTO_SYNC_STARTUP_DELAY_MS="5000"
