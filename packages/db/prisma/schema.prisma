// Prisma Schema — BDO Market Analyzer
// Fonte de dados: PostgreSQL
// Schema modelando items, preços, receitas, inventário e usuários

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// ========================================
// Items do jogo
// ========================================
model Item {
  id            Int      @id // ID do item no BDO (não auto-increment)
  name          String   @db.VarChar(255)
  categoryId    Int?     @map("category_id")
  subCategoryId Int?     @map("sub_category_id")
  weight        Int      @default(0) // Peso em LT (x100 para evitar decimais)
  grade         Int      @default(0) @db.SmallInt // 0=Branco, 1=Verde, 2=Azul, 3=Amarelo, 4=Laranja
  isTradeable   Boolean  @default(true) @map("is_tradeable")
  iconUrl       String?  @map("icon_url") @db.VarChar(512)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  prices           ItemPrice[]
  priceHistory     PriceHistory[]
  recipeIngredients RecipeIngredient[]
  recipesProduced  Recipe[]          @relation("RecipeResult")
  recipesProc      Recipe[]          @relation("RecipeProc")
  canonicalCraftsProduced  CraftingRecipeCraft[]      @relation("CraftingRecipeCraftResult")
  canonicalCraftsProc      CraftingRecipeCraft[]      @relation("CraftingRecipeCraftProc")
  canonicalVariantsProduced CraftingRecipeVariant[]   @relation("CraftingRecipeVariantResult")
  canonicalVariantsProc     CraftingRecipeVariant[]   @relation("CraftingRecipeVariantProc")
  canonicalSlotOptions      CraftingRecipeSlotOption[]
  inventoryEntries UserInventory[]
  inventoryOcrImportItems InventoryOcrImportItem[]

  @@map("items")
}

// ========================================
// Preços atuais dos items (snapshot mais recente)
// ========================================
model ItemPrice {
  id              Int      @id @default(autoincrement())
  itemId          Int      @map("item_id")
  enhancementLevel Int     @default(0) @map("enhancement_level") @db.SmallInt
  basePrice       BigInt   @map("base_price")
  lastSoldPrice   BigInt?  @map("last_sold_price")
  priceMin        BigInt?  @map("price_min")
  priceMax        BigInt?  @map("price_max")
  currentStock    Int      @default(0) @map("current_stock")
  totalTrades     BigInt   @default(0) @map("total_trades")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  item Item @relation(fields: [itemId], references: [id])

  @@unique([itemId, enhancementLevel])
  @@index([itemId])
  @@map("item_prices")
}

// ========================================
// Histórico de preços (uma entrada por dia)
// ========================================
model PriceHistory {
  id              Int      @id @default(autoincrement())
  itemId          Int      @map("item_id")
  enhancementLevel Int     @default(0) @map("enhancement_level") @db.SmallInt
  price           BigInt
  volume          Int      @default(0)
  recordedDate    DateTime @map("recorded_date") @db.Date

  item Item @relation(fields: [itemId], references: [id])

  @@unique([itemId, enhancementLevel, recordedDate])
  @@index([itemId, recordedDate])
  @@map("price_history")
}

// ========================================
// Receitas (cooking, alchemy, processing)
// ========================================
model Recipe {
  id              Int    @id @default(autoincrement())
  name            String @db.VarChar(255)
  type            String @db.VarChar(20) // cooking | alchemy | processing
  resultItemId    Int    @map("result_item_id")
  resultQuantity  Float  @default(1.0) @map("result_quantity")
  procItemId      Int?   @map("proc_item_id")
  procQuantity    Float? @map("proc_quantity")
  masteryBonusPct Int    @default(0) @map("mastery_bonus_pct")
  experience      Int    @default(0)
  cookTimeSeconds Float  @default(1.0) @map("cook_time_seconds")
  categoryId      Int?   @map("category_id")

  resultItem    Item               @relation("RecipeResult", fields: [resultItemId], references: [id])
  procItem      Item?              @relation("RecipeProc", fields: [procItemId], references: [id])
  ingredients   RecipeIngredient[]
  canonicalVariant CraftingRecipeVariant? @relation("LegacyRecipeVariant")
  imperialBoxes ImperialBox[]

  @@map("recipes")
}

// ========================================
// Ingredientes de receitas
// ========================================
model RecipeIngredient {
  id        Int @id @default(autoincrement())
  recipeId  Int @map("recipe_id")
  itemId    Int @map("item_id")
  quantity  Int
  sortOrder Int @default(0) @map("sort_order")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item   @relation(fields: [itemId], references: [id])

  @@index([recipeId])
  @@map("recipe_ingredients")
}

// ========================================
// Modelo canônico variant-first de crafting
// ========================================
model CraftingRecipeCraft {
  id               Int      @id @default(autoincrement())
  canonicalKey     String   @unique @map("canonical_key") @db.VarChar(191)
  name             String   @db.VarChar(255)
  type             String   @db.VarChar(20)
  resultItemId     Int      @map("result_item_id")
  resultQuantity   Float    @default(1.0) @map("result_quantity")
  procItemId       Int?     @map("proc_item_id")
  procQuantity     Float?   @map("proc_quantity")
  masteryBonusPct  Int      @default(0) @map("mastery_bonus_pct")
  experience       Int      @default(0)
  cookTimeSeconds  Float    @default(1.0) @map("cook_time_seconds")
  categoryId       Int?     @map("category_id")
  source           String   @default("seed") @db.VarChar(32)
  curationVersion  Int      @default(1) @map("curation_version")
  curationNotes    String?  @map("curation_notes") @db.Text

  resultItem Item                  @relation("CraftingRecipeCraftResult", fields: [resultItemId], references: [id])
  procItem   Item?                 @relation("CraftingRecipeCraftProc", fields: [procItemId], references: [id])
  variants   CraftingRecipeVariant[]
  slots      CraftingRecipeSlot[]

  @@index([type, resultItemId])
  @@map("crafting_recipe_crafts")
}

model CraftingRecipeVariant {
  id               Int      @id @default(autoincrement())
  craftId          Int      @map("craft_id")
  legacyRecipeId   Int?     @unique @map("legacy_recipe_id")
  variantKey       String   @map("variant_key") @db.VarChar(191)
  name             String   @db.VarChar(255)
  type             String   @db.VarChar(20)
  resultItemId     Int      @map("result_item_id")
  resultQuantity   Float    @default(1.0) @map("result_quantity")
  procItemId       Int?     @map("proc_item_id")
  procQuantity     Float?   @map("proc_quantity")
  masteryBonusPct  Int      @default(0) @map("mastery_bonus_pct")
  experience       Int      @default(0)
  cookTimeSeconds  Float    @default(1.0) @map("cook_time_seconds")
  categoryId       Int?     @map("category_id")
  sortOrder        Int      @default(0) @map("sort_order")
  isPrimary        Boolean  @default(false) @map("is_primary")
  source           String   @default("seed") @db.VarChar(32)

  craft         CraftingRecipeCraft                 @relation(fields: [craftId], references: [id], onDelete: Cascade)
  legacyRecipe  Recipe?                            @relation("LegacyRecipeVariant", fields: [legacyRecipeId], references: [id], onDelete: SetNull)
  resultItem    Item                               @relation("CraftingRecipeVariantResult", fields: [resultItemId], references: [id])
  procItem      Item?                              @relation("CraftingRecipeVariantProc", fields: [procItemId], references: [id])
  slotSelections CraftingRecipeVariantSlotSelection[]

  @@unique([craftId, variantKey])
  @@index([craftId, sortOrder])
  @@index([resultItemId])
  @@map("crafting_recipe_variants")
}

model CraftingRecipeSlot {
  id         Int     @id @default(autoincrement())
  craftId     Int     @map("craft_id")
  slotKey     String  @map("slot_key") @db.VarChar(191)
  label       String? @db.VarChar(255)
  sortOrder   Int     @default(0) @map("sort_order")
  source      String  @default("seed") @db.VarChar(32)

  craft             CraftingRecipeCraft                  @relation(fields: [craftId], references: [id], onDelete: Cascade)
  options           CraftingRecipeSlotOption[]
  variantSelections CraftingRecipeVariantSlotSelection[]

  @@unique([craftId, slotKey])
  @@unique([craftId, sortOrder])
  @@map("crafting_recipe_slots")
}

model CraftingRecipeSlotOption {
  id         Int     @id @default(autoincrement())
  slotId      Int     @map("slot_id")
  itemId      Int     @map("item_id")
  quantity    Int
  sortOrder   Int     @default(0) @map("sort_order")
  label       String? @db.VarChar(255)
  isDefault   Boolean @default(false) @map("is_default")
  source      String  @default("seed") @db.VarChar(32)

  slot              CraftingRecipeSlot                   @relation(fields: [slotId], references: [id], onDelete: Cascade)
  item              Item                                 @relation(fields: [itemId], references: [id])
  variantSelections CraftingRecipeVariantSlotSelection[]

  @@unique([slotId, itemId, quantity])
  @@index([itemId])
  @@map("crafting_recipe_slot_options")
}

model CraftingRecipeVariantSlotSelection {
  id           Int  @id @default(autoincrement())
  variantId     Int  @map("variant_id")
  slotId        Int  @map("slot_id")
  slotOptionId  Int  @map("slot_option_id")
  sortOrder     Int  @default(0) @map("sort_order")

  variant    CraftingRecipeVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  slot       CraftingRecipeSlot       @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotOption CraftingRecipeSlotOption @relation(fields: [slotOptionId], references: [id], onDelete: Cascade)

  @@unique([variantId, slotId])
  @@index([slotOptionId])
  @@map("crafting_recipe_variant_slot_selections")
}

model RecipeCuration {
  id                    Int      @id @default(autoincrement())
  canonicalKey          String   @unique @map("canonical_key") @db.VarChar(191)
  legacyRecipeIds       Int[]    @default([]) @map("legacy_recipe_ids")
  primaryLegacyRecipeId Int?     @map("primary_legacy_recipe_id")
  nameOverride          String?  @map("name_override") @db.VarChar(255)
  notes                 String?  @db.Text
  updatedByUserId       Int?     @map("updated_by_user_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  updatedByUser User?                @relation("RecipeCurationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  slots         RecipeCurationSlot[]
  audits        RecipeCurationAudit[]

  @@index([updatedByUserId])
  @@map("recipe_curations")
}

model RecipeCurationSlot {
  id              Int      @id @default(autoincrement())
  curationId      Int      @map("curation_id")
  slotIndex       Int      @map("slot_index")
  slotKey         String   @map("slot_key") @db.VarChar(191)
  label           String?  @db.VarChar(255)
  defaultItemId   Int?     @map("default_item_id")
  defaultQuantity Int?     @map("default_quantity")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  curation RecipeCuration @relation(fields: [curationId], references: [id], onDelete: Cascade)

  @@unique([curationId, slotIndex])
  @@index([defaultItemId])
  @@map("recipe_curation_slots")
}

model RecipeCurationAudit {
  id          Int      @id @default(autoincrement())
  curationId   Int      @map("curation_id")
  actorUserId  Int?     @map("actor_user_id")
  action       String   @db.VarChar(32)
  payload      Json     @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  curation  RecipeCuration @relation(fields: [curationId], references: [id], onDelete: Cascade)
  actorUser User?          @relation("RecipeCurationAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([curationId, createdAt])
  @@index([actorUserId])
  @@map("recipe_curation_audits")
}

// ========================================
// Usuários
// ========================================
model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique @db.VarChar(100)
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  role           Role     @default(USER)
  familyFame     Int      @default(0) @map("family_fame")
  hasValuePack   Boolean  @default(false) @map("has_value_pack")
  hasMerchRing   Boolean  @default(false) @map("has_merch_ring")
  cookingMastery Int      @default(0) @map("cooking_mastery")
  alchemyMastery Int      @default(0) @map("alchemy_mastery")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  inventory             UserInventory[]
  inventoryOcrImports   InventoryOcrImportBatch[]
  recipeCurationsUpdated RecipeCuration[]     @relation("RecipeCurationUpdatedBy")
  recipeCurationAudits   RecipeCurationAudit[] @relation("RecipeCurationAuditActor")

  @@map("users")
}

// ========================================
// Inventário do usuário
// ========================================
model UserInventory {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  itemId             Int      @map("item_id")
  quantity           Int      @default(0)
  avgAcquisitionCost BigInt?  @map("avg_acquisition_cost")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@index([userId])
  @@map("user_inventory")
}

// ========================================
// Histórico de importação OCR do inventário
// ========================================
model InventoryOcrImportBatch {
  id                   Int      @id @default(autoincrement())
  userId               Int      @map("user_id")
  ocrTexts             Json     @map("ocr_texts")
  importedRowCount     Int      @default(0) @map("imported_row_count")
  importedQuantityTotal Int     @default(0) @map("imported_quantity_total")
  createdAt            DateTime @default(now()) @map("created_at")

  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedItems InventoryOcrImportItem[]

  @@index([userId, createdAt])
  @@map("inventory_ocr_import_batches")
}

model InventoryOcrImportItem {
  id                Int      @id @default(autoincrement())
  batchId           Int      @map("batch_id")
  selectedItemId    Int      @map("selected_item_id")
  rawName           String   @map("raw_name") @db.VarChar(120)
  originalQuantity  Int      @map("original_quantity")
  confirmedQuantity Int      @map("confirmed_quantity")
  score             Float
  selectionSource   String   @map("selection_source") @db.VarChar(16)
  createdAt         DateTime @default(now()) @map("created_at")

  batch        InventoryOcrImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  selectedItem Item                    @relation(fields: [selectedItemId], references: [id])

  @@index([batchId])
  @@index([selectedItemId])
  @@map("inventory_ocr_import_items")
}

// ========================================
// Caixas de Entrega Imperial
// ========================================
model ImperialBox {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255)
  tier           String   @db.VarChar(50) // guru, master, artisan, professional, etc
  type           String   @db.VarChar(50) // cooking, alchemy
  recipeId       Int      @map("recipe_id")
  recipe         Recipe   @relation(fields: [recipeId], references: [id])
  basePrice      BigInt   @map("base_price")
  itemsRequired  Int      @default(1) @map("items_required")

  @@map("imperial_boxes")
}

// ========================================
// Categorias de Receita
// ========================================
model RecipeCategory {
  id       Int      @id @default(autoincrement())
  name     String   @db.VarChar(100)
  type     String   @db.VarChar(50)   // cooking, alchemy, processing
  // Relacionamento com Recipe via categoryId
  // (Pode adicionar se precisar: recipes Recipe[])

  @@map("recipe_categories")
}
